###############################################################################
# face_auth service env — VPS / production profile.
#
# face_auth runs as its OWN compose project (from the face_auth repo). Copy this
# into that repo as .env on the VPS, fill the CHANGE_ME values, then:
#     docker compose -p face_auth up -d
#
# FaceApp's Laravel api reaches this service over the shared docker network at
#     FACE_AUTH_BASE_URL=http://face_auth:8080   (must match API_PORT below)
# set in FaceApp's own .env (.env.vps.example, SECTION A).
#
# Variable names here match the real face_auth repo (PG_*, MINIO_*, …).
###############################################################################

# ---- Postgres — CHANGE for production ----
PG_USER=hik
PG_PASSWORD=CHANGE_ME_strong_db_password
PG_DB=hikpush

# ---- MinIO — CHANGE for production ----
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET=hikpush
MINIO_CONSOLE_PORT=9001
# Public URL base for serving face images. Leave EMPTY to proxy through the
# backend (simplest, keeps MinIO private). Set an https URL only if you
# deliberately expose MinIO directly.
MINIO_PUBLIC_BASE=

# ---- Ports (host) ----
# API_PORT must match FACE_AUTH_BASE_URL in FaceApp's VPS env.
PUSH_PORT=7660
API_PORT=8080
ADMIN_PORT=5173

# Build-time API URL for the face_auth ADMIN UI — the PUBLIC https URL the
# browser uses on the VPS (NOT the FaceApp kiosk; that uses FACEAPP_API_ORIGIN).
VITE_API_URL=https://faceauth.example.com

# ---- Hik device auth ----
# false = device must Login with DEVICE_DEFAULT_PASSWORD (use this in production).
# true  = device auto-registers without login (testing only).
NO_AUTH_MODE=false
DEVICE_DEFAULT_PASSWORD=CHANGE_ME_device_password

LOG_LEVEL=info

# ---- How the Hik device reaches this server ----
# On a VPS these are your PUBLIC hostname/IP (never a LAN 192.168.x address).
# With a LAN agent (below) the agent forwards events instead, and the device
# talks to the agent on the LAN rather than directly to the VPS.
PUBLIC_PUSH_HOST=push.faceauth.example.com
PUBLIC_PUSH_URL=
# IP the device pushes events to via HTTP alarm host (direct-to-VPS topology).
EVENT_CALLBACK_IP=YOUR_VPS_PUBLIC_IP

# Self-signed TLS port for OTAP-over-HTTPS testing. In production you normally
# terminate TLS at the reverse proxy (Caddy) instead of here.
TLS_PORT=7670

# Raw TCP byte dumper for the admin Bridge tab. Handy while bringing a device
# online; consider disabling once stable.
DEBUG_PORT=7661

# ===========================================================================
# face_auth-agent — runs on the LAN box NEXT TO the device, NOT on this VPS.
# These belong in the AGENT machine's env, not here. Listed for reference.
# ===========================================================================
# CLOUD_URL=wss://faceauth.example.com     # wss:// for prod TLS
# AGENT_ID=                                 # created in the admin Agents tab
# AGENT_NAME=LAN agent
# AGENT_TOKEN=                              # copied from the Agents tab
# QR_STRIP_PREFIX=in#                       # scanner emits "in#TOKEN" → strip "in#"
# QR_STRIP_SUFFIX=
# QR_LISTEN_PORT=7771
# QR_DEVICE=                                # /dev/input/by-id/...-event-kbd (Linux)
# QR_DEVICE_AUTO=                           # "true" → auto-pick a scanner device
