###############################################################################
# LOCAL TESTING profile — FaceApp stack + face_auth service combined.
#
# Same keys as .env.example, but tuned for local testing (localtest.me, http,
# TEST_* credentials). Copy to .env for a local run:  cp .env.local.example .env
# Each compose project reads only the vars it references; sharing one file is safe.
###############################################################################

# ===========================================================================
# SECTION A — FaceApp stack (local testing)
# ===========================================================================

COMPOSE_PROJECT_NAME=faceapp-stack

FACEAPP_DOMAIN=faceapp.localtest.me
FACEAPP_API_DOMAIN=faceapp-api.localtest.me
FACEAPP_API_ORIGIN=http://faceapp-api.localtest.me

LARAVEL_APP_ENV=production
LARAVEL_APP_DEBUG=false
LARAVEL_APP_KEY=base64:KeNF/zMNUppHZ7jLIQHJuGrhhZRL7rqpqChDWPqgxf8=
# Origin is plain http for local testing, so the session cookie must NOT be
# secure-only — otherwise Laravel won't set it over http. (Prod uses https → true.)
LARAVEL_SESSION_SECURE_COOKIE=false

GATEWAY_DEVICE_KEY=TEST_DEVICE_KEY
GATEWAY_SECRET=TEST_DEVICE_SECRET
GATEWAY_TIMEOUT_SECONDS=10
GATEWAY_DEFAULT_PERSON_TYPE=1
GATEWAY_DEFAULT_VERIFY_STYLE=1
GATEWAY_DEFAULT_AC_GROUP_NUMBER=0
GATEWAY_DEFAULT_PHOTO_QUALITY=1
GATEWAY_IMAGE_BASE_URL=http://faceapp-api.localtest.me/storage

GATEWAY_DEVICE_PORT=10010
GATEWAY_SDK_PORT=10011

# ---- FaceApp → face_auth integration (Laravel api container) ----
# Over the shared docker network face_auth resolves by service name on API_PORT
# (section B). If you instead run face_auth on the host, use http://localhost:8080.
FACE_AUTH_BASE_URL=http://face_auth:8080
# Mint this in the face_auth admin UI and paste it here. Server-side only.
FACE_AUTH_API_KEY=
FACE_AUTH_DEFAULT_DEVICE_ID=
FACE_AUTH_TIMEOUT_SECONDS=10
FACE_AUTH_POLL_MAX_SECONDS=60
FACE_AUTH_POLL_INTERVAL_MS=1500
FACE_AUTH_GATE_MODE=app_turnstile
# Keep true even locally — face_auth does return matchedEmployeeNo, so the
# fail-closed check passes. Only set false if you deliberately test the
# missing-identity fallback path.
FACE_AUTH_REQUIRE_MATCHED_IDENTITY=true

# ===========================================================================
# SECTION B — face_auth service (Go + Fiber, Postgres + Redis + MinIO + agent)
# Run from the face_auth repo: docker compose -p face_auth up -d
# ===========================================================================

# Postgres
PG_USER=hik
PG_PASSWORD=hikpush
PG_DB=hikpush

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=hikpush
MINIO_CONSOLE_PORT=9001
# Public URL base for serving images (leave empty to proxy via backend)
MINIO_PUBLIC_BASE=

# Ports exposed on host
PUSH_PORT=7660
# face_auth backend port. FACE_AUTH_BASE_URL (section A) must point here.
API_PORT=8080
ADMIN_PORT=5173

# Build-time API URL for the face_auth ADMIN UI (not the FaceApp kiosk).
VITE_API_URL=http://localhost:8080

# Auth mode for Hik devices
# true  = device skips Login, auto-registers on first contact (easiest for testing)
# false = device must Login with matching DEVICE_DEFAULT_PASSWORD
NO_AUTH_MODE=false
DEVICE_DEFAULT_PASSWORD=crave2168

LOG_LEVEL=info

# ---- face_auth-agent (LAN-side bridge for cloud deployments) ----
# Cloud URL the agent should connect to (use ws:// for local, wss:// for prod TLS).
CLOUD_URL=ws://localhost:8080
# Agent ID + name (you create these in the Agents tab; copy the token from there).
AGENT_ID=
AGENT_NAME=LAN agent
AGENT_TOKEN=

# USB QR scanner: strip this from the start / end of every scan before
# forwarding to the cloud. e.g. scanner emits "in#TOKEN" → set QR_STRIP_PREFIX=in#
QR_STRIP_PREFIX=in#
QR_STRIP_SUFFIX=
QR_LISTEN_PORT=7771

# Native USB QR scanner (Linux only). The agent opens this device and reads
# keystrokes directly — no helper script needed.
#   QR_DEVICE       = explicit path (preferred): /dev/input/eventN
#                     or /dev/input/by-id/usb-MyScanner-event-kbd
#   QR_DEVICE_AUTO  = "true" → agent auto-picks a scanner-looking device
QR_DEVICE=
QR_DEVICE_AUTO=

# Raw TCP byte dumper — when set (e.g. 7661) it captures whatever protocol the device
# speaks and exposes it via the admin Bridge tab. Recommended to leave on for testing.
DEBUG_PORT=7661

# Public host/port the device will use to reach this server.
# - For LAN testing: same as your machine's LAN IP (e.g. 192.168.100.69)
# - For cloud: your VPS hostname / IP
PUBLIC_PUSH_HOST=192.168.100.69
PUBLIC_PUSH_URL=

# If set, backend also listens on this port with a self-signed TLS cert.
TLS_PORT=7670

# IP address the Hik device should push events to via HTTP alarm host.
# Set this to the IP of THIS host on the LAN that the device can reach.
EVENT_CALLBACK_IP=192.168.100.69
