COMPOSE_PROJECT_NAME=faceapp-stack

FACEAPP_DOMAIN=faceapp.example.com
FACEAPP_API_DOMAIN=api.faceapp.example.com
FACEAPP_API_ORIGIN=https://api.faceapp.example.com

LARAVEL_APP_ENV=production
LARAVEL_APP_DEBUG=false
LARAVEL_APP_NAME=FaceApp API
# Generate with:
# php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
LARAVEL_APP_KEY=
LARAVEL_SESSION_COOKIE=faceapp_api_session
# Leave blank for a host-only cookie. This is the safest option for the
# FaceApp admin/API domain behind the shared reverse proxy.
LARAVEL_SESSION_DOMAIN=
LARAVEL_SESSION_SECURE_COOKIE=true

GATEWAY_DEVICE_KEY=YOUR_DEVICE_KEY
GATEWAY_SECRET=YOUR_DEVICE_SECRET
GATEWAY_TIMEOUT_SECONDS=10
GATEWAY_DEFAULT_PERSON_TYPE=1
GATEWAY_DEFAULT_VERIFY_STYLE=1
GATEWAY_DEFAULT_AC_GROUP_NUMBER=0
GATEWAY_DEFAULT_PHOTO_QUALITY=1
GATEWAY_IMAGE_BASE_URL=http://api.faceapp.example.com/storage
GATEWAY_CALLBACK_BASE_URL=http://api.faceapp.example.com
GATEWAY_PERSON_VERIFY_RETRIES=5
GATEWAY_PERSON_VERIFY_DELAY_MS=1000
GATEWAY_VERIFY_RETRIES=5
GATEWAY_VERIFY_DELAY_MS=1500
GATEWAY_HEARTBEAT_INTERVAL_SECONDS=60
GATEWAY_ONLINE_WINDOW_SECONDS=180

GATEWAY_DEVICE_PORT=10010
GATEWAY_SDK_PORT=10011

FACEAPP_PROXY_HTTP_PORT=8082

FACEAPP_EXTERNAL_API_TOKEN=

# ---- FaceApp → face_auth integration (read by the Laravel api container) ----
# face_auth runs as its OWN compose project on the VPS (Postgres/Redis/MinIO).
# Reach it over the shared docker network by service name + its API_PORT.
# From the host you'd use http://127.0.0.1:8080 instead.
FACE_AUTH_BASE_URL=http://face_auth:8080
# Mint this in the face_auth admin UI, then paste here. Server-side only —
# never exposed to the browser.
FACE_AUTH_API_KEY=
# A device id from face_auth's GET /api/v1/devices.
FACE_AUTH_DEFAULT_DEVICE_ID=
FACE_AUTH_TIMEOUT_SECONDS=10
FACE_AUTH_POLL_MAX_SECONDS=60
FACE_AUTH_POLL_INTERVAL_MS=1500
# app_turnstile = face_auth verifies only, the app opens the gate (default/safe)
# face_auth_open_door = the Hik relay is wired to the turnstile; face_auth opens it
FACE_AUTH_GATE_MODE=app_turnstile
# Fail-closed: keep true in production (gate opens only on a matched identity).
FACE_AUTH_REQUIRE_MATCHED_IDENTITY=true
